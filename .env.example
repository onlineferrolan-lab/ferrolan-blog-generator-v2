# Ferrolan Blog Generator — Variables de entorno

# ─── OBLIGATORIAS ───────────────────────────────

# Contraseña de acceso a la app. Sin ella, en producción se deniega todo
# (fail-closed). En desarrollo local puede omitirse.
AUTH_PASSWORD=
# Salt del token de sesión (recomendado definirlo en producción)
AUTH_SECRET=

# Secreto del cron de autopublicación. OBLIGATORIO para que /api/cron/publish
# funcione: Vercel lo envía como "Authorization: Bearer ..." automáticamente
# al definir la variable CRON_SECRET en el proyecto.
CRON_SECRET=

# API key de Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# API key de OpenAI para generación de imágenes (gpt-image-1)
OPENAI_API_KEY=sk-...

# Vercel KV (se configura automáticamente al vincular el store en Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── OPCIONALES — Google Search Console (Panel GSC en vivo) ─────────

# Para datos en vivo, crea una Service Account en Google Cloud Console
# y añade el email como usuario en Google Search Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GSC_SITE_URL=sc-domain:ferrolan.es

# Sin estas variables, el panel GSC muestra datos estáticos del último análisis

# ─── OPCIONALES — Prestashop (Panel Keywords) ───────────────────────

# API key del webservice de Prestashop (solo permisos GET)
PRESTASHOP_API_KEY=
PRESTASHOP_API_URL=https://ferrolan.es/api

# ─── OPCIONALES — Google Sheet para Keywords ─────────────────────────

# ID del Sheet donde sincronizar las keywords generadas
KEYWORDS_SHEET_ID=

# ─── OPCIONALES — Resumen quincenal por email (SMTP) ─────────────────
# Cron /api/cron/article-digest (días 1 y 16): manda un par de propuestas
# de artículo ya generadas + informe de metadatos/keywords.
# SMTP Gmail (por defecto): smtp.gmail.com:465 SSL · usa contraseña de aplicación.
# SMTP Outlook/365: SMTP_HOST=smtp.office365.com y SMTP_PORT=587.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Remitente (opcional; por defecto = SMTP_USER) y destinatario del resumen
DIGEST_EMAIL_FROM=
DIGEST_EMAIL_TO=
