# Ferrolan Blog Generator — Variables de entorno

# ─── OBLIGATORIAS ───────────────────────────────

# API key de Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# API key de Google Gemini para imágenes
GEMINI_API_KEY=AIza...

# Vercel KV (se configura automáticamente al vincular el store en Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── OPCIONALES — Google Search Console (Panel GSC en vivo) ─────────

# Para datos en vivo, crea una Service Account en Google Cloud Console
# y añade el email como usuario en Google Search Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GSC_SITE_URL=sc-domain:ferrolan.es

# Sin estas variables, el panel GSC muestra datos estáticos del último análisis

# ─── OPCIONALES — Prestashop (Panel Keywords) ───────────────────────

# API key del webservice de Prestashop (solo permisos GET)
PRESTASHOP_API_KEY=
PRESTASHOP_API_URL=https://ferrolan.es/api

# ─── OPCIONALES — Google Sheet para Keywords ─────────────────────────

# ID del Sheet donde sincronizar las keywords generadas
KEYWORDS_SHEET_ID=
